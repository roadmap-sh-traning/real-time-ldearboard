# Local dev (Postgres exposed on host port 5433 via docker compose)
DATABASE_URL=postgresql://real-time-lb:real-time-lb@127.0.0.1:5433/real-time-lb

# Redis (docker compose exposes 6379 on localhost)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Production / Railway: reference Redis service vars on the app (do not use 127.0.0.1)
# REDIS_URL=redis://default:password@redis.railway.internal:6379
# Or: REDISHOST, REDISPORT, REDISPASSWORD, REDISUSER (provided by Railway)

# JWT
JWT_SECRET=super-secret-key
