{
  "extends": "fastify-tsconfig",
  "compilerOptions": {
    "outDir": "dist",
    "sourceMap": true,
  },
  "include": ["src/**/*.ts", "src/types/fastify.d.ts"],
  "baseUrl": "./",
  "paths": {
    "@src/*": ["src/*"],
    "@type/*": ["src/type/*"],
    "@lib/*": ["src/lib/*"],
    "@test/*": ["test/*"],
  },
}
